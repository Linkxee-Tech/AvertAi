# Copy this file to .env and fill in real values before deploying.
# Every value below has a safe local-dev default in app/core/config.py,
# so the app runs with an empty .env — these are only required for production
# or to exercise the real third-party integrations instead of their mocks.

# --- App ---
ENV=development
CORS_ORIGINS=["*"]

# --- Database (DigitalOcean Managed PostgreSQL + PostGIS + TimescaleDB) ---
# Local dev: leave unset to use SQLite (./avertai.db)
DATABASE_URL=postgresql+psycopg2://avertai_user:CHANGE_ME@your-db-cluster.db.ondigitalocean.com:25060/avertai?sslmode=require

# --- Redis (DigitalOcean Managed Redis) ---
REDIS_URL=redis://default:CHANGE_ME@your-redis-cluster.db.ondigitalocean.com:25061

# --- Auth ---
SECRET_KEY=replace-with-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Africa's Talking (SMS / USSD / Voice) ---
# https://account.africastalking.com — leave blank to use the console-log mock
AFRICAS_TALKING_USERNAME=
AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_SENDER_ID=AvertAI

# --- Twilio (fallback provider — circuit breaker if Africa's Talking fails) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Firebase Cloud Messaging (push notifications) ---
FCM_SERVER_KEY=

# --- Google Cloud (Vertex AI training/inference, Cloud TTS, GCS storage) ---
GCP_PROJECT_ID=
GCS_BUCKET_NAME=
GOOGLE_APPLICATION_CREDENTIALS=./gcp-service-account.json

# --- ML model registry ---
MODEL_REGISTRY_PATH=./model_registry
ACTIVE_MODEL_VERSION=v2.3.1
