{
    "hosting":  {
                    "public":  ".",
                    "ignore":  [
                                   "firebase.json",
                                   "**/.*",
                                   "**/node_modules/**"
                               ],
                    "rewrites":  [
                                     {
                                         "source":  "**",
                                         "destination":  "/index.html"
                                     }
                                 ],
                    "headers":  [
                                    {
                                        "headers":  [
                                                        {
                                                            "key":  "Cache-Control",
                                                            "value":  "no-cache, no-store, must-revalidate"
                                                        }
                                                    ],
                                        "source":  "**/*.html"
                                    }
                                ]
                }
}
